<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:requestLegacyExternalStorage="true">

        <!-- Splash Screen -->
        <activity
            android:name=".SplashActivity"
            android:theme="@style/SplashTheme"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Screen -->
        <activity
            android:name=".MainActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <!-- 3D Editor -->
        <activity
            android:name=".EditorActivity"
            android:theme="@style/EditorTheme"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="false" />

        <!-- Project List -->
        <activity
            android:name=".ProjectListActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <!-- Settings -->
        <activity
            android:name=".SettingsActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <!-- Texture Library -->
        <activity
            android:name=".TextureLibraryActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <!-- Custom Blocks -->
        <activity
            android:name=".CustomBlocksActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <!-- Export -->
        <activity
            android:name=".ExportActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <!-- Import Project -->
        <activity
            android:name=".ProjectImportActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <!-- Share Project -->
        <activity
            android:name=".ProjectShareActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <!-- UV Editor -->
        <activity
            android:name=".uv.UVEditorActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <!-- FileProvider for sharing -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
